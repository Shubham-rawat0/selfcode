generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role{
  USER
  ASSISTANT
  ERROR
}

enum Mode {
  BUILD
  PLAN
}

enum MessageStatus{
  COMPLETE
  INTERRUPTED
}

model Session {
  id          String        @id @default(cuid())
  userId      String
  title       String
  cwd         String?
  createdAt   DateTime      @default(now())
  updatedAT   DateTime      @updatedAt
  messages    Message[]
  @@index([userId])
} 

model Message{
  id         String    @id  @default(cuid())
  sessionId  String
  role       Role
  status     MessageStatus
  content    String
  parts      Json?
  model      String
  mode       Mode
  duration   Int?
  createdAt  DateTime  @default(now())
  Session    Session   @relation(fields: [sessionId],references:[id] , onDelete:Cascade)
  @@index([sessionId])
}