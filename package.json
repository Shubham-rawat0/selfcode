{
    "name": "selfcode",
    "version": "1.0.0",
    "workspaces": ["packages/*"],
    "scripts": {
        "dev:cli": "bun run --watch packages/cli/src/index.js",
        "dev:server": "bun run --hot packages/server/src/index.js",
        "build:cli":"bun run --filter @selfcode/cli build",
        "link:cli":"bun run build:cli && cd packages/cli && bun link"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "bun-types": "^1.3.14"
    },
    "dependencies": {
        "dotenv": "^17.4.2"
    }
}